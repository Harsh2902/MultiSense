# =============================================================================
# Student Learning Platform — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# =============================================================================

# =============================================================================
# Supabase (REQUIRED)
# Get these from Supabase project settings > API
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — ONLY used server-side. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# AI Providers (REQUIRED: at least GROQ_API_KEY)
# =============================================================================
GROQ_API_KEY=gsk_your-groq-api-key-here

# Optional: needed for embeddings (text-embedding-3-small)
# OPENAI_API_KEY=sk-your-openai-api-key

# =============================================================================
# AI Configuration (optional — sensible defaults provided)
# =============================================================================
# AI_PROVIDER=groq                          # groq | openai | anthropic
# AI_DEFAULT_MODEL=llama-3.1-8b-instant     # Chat model
# AI_EMBEDDING_MODEL=text-embedding-3-small # Embedding model
# AI_EMBEDDING_DIMENSIONS=1536              # Must match model output
# AI_MAX_TOKENS=2048                        # Max response tokens
# AI_TEMPERATURE=0.7                        # Response creativity
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# =============================================================================
# Rate Limiting — Upstash Redis (recommended for production)
# Get these from Upstash Console
# =============================================================================
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-redis-token-here
# RATE_LIMIT_CHAT=30                        # Requests per minute
# RATE_LIMIT_UPLOAD=5                       # Uploads per minute
# RATE_LIMIT_YOUTUBE=3                      # YouTube submissions per minute

# =============================================================================
# Application
# =============================================================================
# NEXT_PUBLIC_APP_URL=http://localhost:3000  # Your public app URL
# NODE_ENV=development                      # development | production | test
# LOG_LEVEL=info                            # debug | info | warn | error

# =============================================================================
# Token Governance (optional)
# =============================================================================
# DAILY_TOKEN_BUDGET=500000                 # Per-user daily token limit

# =============================================================================
# Processing Concurrency (optional)
# =============================================================================
# MAX_PARALLEL_OCR=3
# MAX_PARALLEL_EMBEDDINGS=5
# MAX_PARALLEL_LLM=4
# MAX_FILE_SIZE=10485760                    # 10MB in bytes
# CONTEXT_WINDOW_TOKENS=4096

# =============================================================================
# Worker Process (for standalone background worker)
# =============================================================================
# WORKER_POLL_BASE_MS=2000                  # Base poll interval (ms)
# WORKER_POLL_MAX_MS=30000                  # Max backoff interval (ms)
# WORKER_BATCH_SIZE=5                       # Jobs per poll cycle

# =============================================================================
# Health Check (recommended for production)
# =============================================================================
# HEALTH_CHECK_SECRET=your-random-secret    # Required for /api/health?detail=true

# =============================================================================
# OAuth Providers (configure in Supabase Dashboard > Authentication > Providers)
# =============================================================================
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
