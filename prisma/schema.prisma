generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  full_name        String?
  avatar_url       String?
  preferences      Json             @default("{}")
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  conversations    Conversation[]
  learning_sources LearningSource[]
  summaries        Summary[]
  quizzes          Quiz[]
  quiz_attempts    QuizAttempt[]
  flashcard_sets   FlashcardSet[]
  token_usage      TokenUsage[]

  @@map("users")
}

// ... skipping conversation ... wait I need to specify exactly.

model TokenUsage {
  id                 String   @id @default(uuid())
  user_id            String
  date               String   // YYYY-MM-DD
  feature            String
  total_tokens       Int      @default(0)
  estimated_cost_usd Float    @default(0)
  created_at         DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@unique([user_id, date, feature])
  @@map("token_usage")
}

model Conversation {
  id               String           @id @default(uuid())
  user_id          String
  title            String
  mode             String           @default("chat")
  settings         Json             @default("{}")
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  user             User             @relation(fields: [user_id], references: [id])
  messages         Message[]
  learning_sources LearningSource[]
  summaries        Summary[]
  quizzes          Quiz[]
  flashcard_sets   FlashcardSet[]

  @@map("conversations")
}

model Message {
  id              String       @id @default(uuid())
  conversation_id String
  role            String
  content         String       @db.Text
  metadata        Json         @default("{}")
  token_count     Int?
  created_at      DateTime     @default(now())
  conversation    Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("messages")
}

model LearningSource {
  id                String        @id @default(uuid())
  user_id           String
  conversation_id   String?
  source_type       String
  source_url        String?       @db.Text
  title             String        @db.Text
  original_filename String?       @db.Text
  file_type         String
  status            String        @default("pending")
  metadata          Json          @default("{}")
  chunks_count      Int           @default(0)
  file_size         Int?
  storage_path      String?       @db.Text
  error_message     String?       @db.Text
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt
  user              User          @relation(fields: [user_id], references: [id])
  conversation      Conversation? @relation(fields: [conversation_id], references: [id], onDelete: SetNull)
  source_chunks     SourceChunk[]

  @@map("learning_sources")
}

model SourceChunk {
  id          String                      @id @default(uuid())
  source_id   String
  chunk_index Int
  content     String                      @db.Text
  token_count Int
  embedding   Unsupported("vector(768)")?
  metadata    Json                        @default("{}")
  created_at  DateTime                    @default(now())
  source      LearningSource              @relation(fields: [source_id], references: [id], onDelete: Cascade)

  @@map("source_chunks")
}

model Summary {
  id              String       @id @default(uuid())
  user_id         String
  conversation_id String
  summary_type    String
  title           String       @db.Text
  content         String?      @db.Text
  status          String       @default("pending")
  word_count      Int          @default(0)
  version         Int          @default(1)
  metadata        Json         @default("{}")
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  user         User         @relation(fields: [user_id], references: [id])
  conversation Conversation @relation(fields: [conversation_id], references: [id])

  @@map("summaries")
}

model Quiz {
  id              String         @id @default(uuid())
  user_id         String
  conversation_id String
  title           String         @db.Text
  status          String         @default("pending")
  question_count  Int            @default(0)
  metadata        Json           @default("{}")
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  user         User           @relation(fields: [user_id], references: [id])
  conversation Conversation   @relation(fields: [conversation_id], references: [id])
  questions    QuizQuestion[]
  attempts     QuizAttempt[]

  @@map("quizzes")
}

model QuizQuestion {
  id                   String   @id @default(uuid())
  quiz_id              String
  question_index       Int
  question_text        String   @db.Text
  options              String[]
  correct_option_index Int
  explanation          String   @db.Text
  source_chunk_ids     String[]
  created_at           DateTime @default(now())

  quiz Quiz @relation(fields: [quiz_id], references: [id], onDelete: Cascade)

  @@map("quiz_questions")
}

model QuizAttempt {
  id           String   @id @default(uuid())
  quiz_id      String
  user_id      String
  answers      Json     @default("[]")
  answer_hash  String?
  score        Int      @default(0)
  percentage   Float    @default(0)
  completed_at DateTime @default(now())
  created_at   DateTime @default(now())

  quiz Quiz @relation(fields: [quiz_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id])

  @@map("quiz_attempts")
}

model FlashcardSet {
  id              String      @id @default(uuid())
  user_id         String
  conversation_id String
  title           String      @db.Text
  status          String      @default("pending")
  card_count      Int         @default(0)
  metadata        Json        @default("{}")
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt

  user         User         @relation(fields: [user_id], references: [id])
  conversation Conversation @relation(fields: [conversation_id], references: [id])
  flashcards   Flashcard[]

  @@map("flashcard_sets")
}

model Flashcard {
  id               String    @id @default(uuid())
  set_id           String
  card_index       Int
  front            String    @db.Text
  back             String    @db.Text
  is_learned       Boolean   @default(false)
  review_count     Int       @default(0)
  last_reviewed_at DateTime?
  source_chunk_ids String[]
  created_at       DateTime  @default(now())

  set FlashcardSet @relation(fields: [set_id], references: [id], onDelete: Cascade)

  @@map("flashcards")
}
